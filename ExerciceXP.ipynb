    "def insertion_sort_optimized(numbers: list) -> None:\n",
    "    \"\"\"\n",
    "    Version optimisée du tri par insertion utilisant une sentinelle.\n",
    "    \"\"\"\n",
    "    if len(numbers) <= 1:\n",
    "        return\n",
    "    \n",
    "    # Trouver le minimum et le mettre en première position (sentinelle)\n",
    "    min_idx = 0\n",
    "    for i in range(1, len(numbers)):\n",
    "        if numbers[i] < numbers[min_idx]:\n",
    "            min_idx = i\n",
    "    numbers[0], numbers[min_idx] = numbers[min_idx], numbers[0]\n",
    "    \n",
    "    # Tri par insertion standard avec sentinelle\n",
    "    for i in range(2, len(numbers)):\n",
    "        current = numbers[i]\n",
    "        j = i - 1\n",
    "        \n",
    "        # Pas besoin de vérifier j >= 0 grâce à la sentinelle\n",
    "        while numbers[j] > current:\n",
    "            numbers[j + 1] = numbers[j]\n",
    "            j -= 1\n",
    "        \n",
    "        numbers[j + 1] = current\n",
    "\n",
    "# Test\n",
    "numbers = [5, 2, 9, 1, 5, 6]\n",
    "insertion_sort_optimized(numbers)\n",
    "print(f\"\\nTri optimisé: {numbers}\")"
   ]
