        "import time\n",
        "import random\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "def linear_search(numbers: list, value: int) -> int:\n",
        "    \"\"\"Recherche linéaire pour comparaison.\"\"\"\n",
        "    for i, num in enumerate(numbers):\n",
        "        if num == value:\n",
        "            return i\n",
        "    return -1\n",
        "\n",
        "def compare_search_algorithms():\n",
        "    \"\"\"\n",
        "    Compare les performances de la recherche binaire vs linéaire.\n",
        "    \"\"\"\n",
        "    sizes = [10, 100, 1000, 10000, 100000]\n",
        "    times_binary = []\n",
        "    times_linear = []\n",
        "\n",
        "    print(\"\\n=== COMPARAISON DES PERFORMANCES ===\")\n",
        "    print(f\"{'Taille':<10} {'Binaire (s)':<15} {'Linéaire (s)':<15} {'Ratio':<10}\")\n",
        "    print(\"-\" * 50)\n",
        "\n",
        "    for size in sizes:\n",
        "        # Créer un tableau trié\n",
        "        numbers = list(range(size))\n",
        "\n",
        "        # Chercher un élément qui existe (le dernier)\n",
        "        target = size - 1\n",
