        "def binary_search_first_occurrence(numbers: list, value: int) -> int:\n",
        "    \"\"\"\n",
        "    Recherche binaire qui retourne la première occurrence d'un élément.\n",
        "    Utile pour les tableaux avec doublons.\n",
        "    \"\"\"\n",
        "    low = 0\n",
        "    high = len(numbers) - 1\n",
        "    result = -1\n",
        "\n",
        "    while low <= high:\n",
        "        mid = (low + high) // 2\n",
        "\n",
        "        if numbers[mid] == value:\n",
        "            result = mid\n",
        "            high = mid - 1  # Continuer à chercher à gauche\n",
        "        elif numbers[mid] < value:\n",
        "            low = mid + 1\n",
        "        else:\n",
        "            high = mid - 1\n",
        "\n",
        "    return result\n",
        "\n",
        "def binary_search_last_occurrence(numbers: list, value: int) -> int:\n",
        "    \"\"\"\n",
        "    Recherche binaire qui retourne la dernière occurrence d'un élément.\n",
        "    \"\"\"\n",
        "    low = 0\n",
        "    high = len(numbers) - 1\n",
        "    result = -1\n",
        "\n",
        "    while low <= high:\n",
        "        mid = (low + high) // 2\n",
        "\n",
        "        if numbers[mid] == value:\n",
        "            result = mid\n",
        "            low = mid + 1  # Continuer à chercher à droite\n",
        "        elif numbers[mid] < value:\n",
        "            low = mid + 1\n",
        "        else:\n",
        "            high = mid - 1\n",
        "\n",
        "    return result\n",
        "\n",
        "# Test avec doublons\n",
        "numbers_with_duplicates = [1, 2, 3, 3, 3, 4, 5, 5, 6]\n",
        "print(f\"\\n=== GESTION DES DOUBLONS ===\")\n",
        "print(f\"Tableau: {numbers_with_duplicates}\")\n",
        "print(f\"Première occurrence de 3: {binary_search_first_occurrence(numbers_with_duplicates, 3)}\")\n",
        "print(f\"Dernière occurrence de 3: {binary_search_last_occurrence(numbers_with_duplicates, 3)}\")\n",
        "print(f\"Première occurrence de 5: {binary_search_first_occurrence(numbers_with_duplicates, 5)}\")\n",
        "print(f\"Dernière occurrence de 5: {binary_search_last_occurrence(numbers_with_duplicates, 5)}\")"
      ]
