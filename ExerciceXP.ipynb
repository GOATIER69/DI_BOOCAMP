    "def binary_search_visual(numbers: list, value: int) -> int:\n",
    "    \"\"\"\n",
    "    Version de la recherche binaire avec visualisation des étapes.\n",
    "    \"\"\"\n",
    "    low = 0\n",
    "    high = len(numbers) - 1\n",
    "    step = 1\n",
    "    \n",
    "    print(f\"Recherche de {value} dans {numbers}\")\n",
    "    print(\"=\" * 50)\n",
    "    \n",
    "    while low <= high:\n",
    "        mid = (low + high) // 2\n",
    "        \n",
    "        print(f\"\\nÉtape {step}:\")\n",
    "        print(f\"  low = {low}, high = {high}, mid = {mid}\")\n",
    "        print(f\"  Element mid: {numbers[mid]}\")\n",
    "        \n",
    "        # Visualisation du tableau avec pointeurs\n",
