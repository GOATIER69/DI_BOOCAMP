        "def binary_search_rotation_point(arr):\n",
        "    \"\"\"\n",
        "    Trouve le point de rotation dans un tableau trié par rotation.\n",
        "    Exemple: [4, 5, 6, 7, 0, 1, 2] → retourne l'index de 0 (4)\n",
        "    \"\"\"\n",
        "    if len(arr) <= 1:\n",
        "        return 0\n",
        "\n",
        "    low, high = 0, len(arr) - 1\n",
        "\n",
        "    while low < high:\n",
        "        mid = (low + high) // 2\n",
        "\n",
        "        if arr[mid] > arr[high]:\n",
        "            low = mid + 1\n",
        "        else:\n",
        "            high = mid\n",
        "\n",
        "    return low\n",
        "\n",
        "def binary_search_in_rotated(arr, target):\n",
        "    \"\"\"\n",
        "    Recherche binaire dans un tableau trié par rotation.\n",
        "    \"\"\"\n",
        "    def search(arr, target, low, high):\n",
        "        if low > high:\n",
        "            return -1\n",
        "\n",
        "        mid = (low + high) // 2\n",
        "\n",
        "        if arr[mid] == target:\n",
        "            return mid\n",
        "\n",
        "        # Si la moitié gauche est triée\n",
        "        if arr[low] <= arr[mid]:\n",
        "            if arr[low] <= target <= arr[mid]:\n",
        "                return search(arr, target, low, mid - 1)\n",
        "            return search(arr, target, mid + 1, high)\n",
        "\n",
        "        # Sinon la moitié droite est triée\n",
        "        if arr[mid] <= target <= arr[high]:\n",
        "            return search(arr, target, mid + 1, high)\n",
        "        return search(arr, target, low, mid - 1)\n",
        "\n",
        "    return search(arr, target, 0, len(arr) - 1)\n",
        "\n",
        "# Test\n",
        "rotated = [4, 5, 6, 7, 0, 1, 2]\n",
        "print(f\"\\n=== RECHERCHE DANS UN TABLEAU ROTATÉ ===\")\n",
        "print(f\"Tableau: {rotated}\")\n",
        "print(f\"Point de rotation: {binary_search_rotation_point(rotated)} (index de l'élément minimum)\")\n",
        "print(f\"Recherche de 0: {binary_search_in_rotated(rotated, 0)}\")\n",
        "print(f\"Recherche de 6: {binary_search_in_rotated(rotated, 6)}\")"
      ]
    }
