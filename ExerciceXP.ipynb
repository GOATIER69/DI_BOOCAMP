    "import bisect\n",
    "\n",
    "def binary_search_builtin(numbers: list, value: int) -> int:\n",
    "    \"\"\"\n",
    "    Utilisation du module bisect de la bibliothèque standard Python.\n",
    "    \"\"\"\n",
    "    index = bisect.bisect_left(numbers, value)\n",
    "    if index < len(numbers) and numbers[index] == value:\n",
    "        return index\n",
    "    return -1\n",
    "\n",
    "print(\"\\n=== UTILISATION DU MODULE BISECT ===\")\n",
    "numbers = [1, 3, 5, 7, 9, 11]\n",
    "print(f\"Index de 7: {binary_search_builtin(numbers, 7)}\")\n",
    "print(f\"Index de 11: {binary_search_builtin(numbers, 11)}\")"
