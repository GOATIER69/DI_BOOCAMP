        "        insertion_sort(arr_best.copy())\n",
        "        times_best.append(time.perf_counter() - start)\n",
        "\n",
        "        # Pire cas (ordre inverse)\n",
        "        arr_worst = list(range(size, 0, -1))\n",
        "        start = time.perf_counter()\n",
        "        insertion_sort(arr_worst.copy())\n",
        "        times_worst.append(time.perf_counter() - start)\n",
