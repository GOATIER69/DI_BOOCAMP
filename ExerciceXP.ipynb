        "def binary_search_recursive(numbers: list, value: int, low: int = 0, high: int = None) -> int:\n",
        "    \"\"\"\n",
        "    Version récursive de la recherche binaire.\n",
        "    \"\"\"\n",
        "    if high is None:\n",
        "        high = len(numbers) - 1\n",
        "\n",
        "    if low > high:\n",
        "        return -1\n",
        "\n",
        "    mid = (low + high) // 2\n",
        "\n",
        "    if numbers[mid] == value:\n",
        "        return mid\n",
        "    elif numbers[mid] < value:\n",
        "        return binary_search_recursive(numbers, value, mid + 1, high)\n",
        "    else:\n",
        "        return binary_search_recursive(numbers, value, low, mid - 1)\n",
        "\n",
        "# Test\n",
        "print(f\"\\n=== VERSION RÉCURSIVE ===\")\n",
        "print(f\"Index de 7: {binary_search_recursive(numbers, 7)}\")\n",
        "print(f\"Index de 11: {binary_search_recursive(numbers, 11)}\")\n",
        "print(f\"Index de 4: {binary_search_recursive(numbers, 4)}\")"
      ]
    },
