        "def binary_search(numbers: list, value: int) -> int:\n",
        "    \"\"\"\n",
        "    Recherche binaire itérative pour trouver un élément dans un tableau trié.\n",
        "\n",
        "    Args:\n",
        "        numbers: Liste triée d'éléments\n",
        "        value: Valeur à rechercher\n",
        "\n",
        "    Returns:\n",
        "        int: Index de la valeur si trouvée, -1 sinon\n",
        "    \"\"\"\n",
        "    low = 0\n",
        "    high = len(numbers) - 1\n",
        "\n",
        "    while low <= high:\n",
        "        mid = (low + high) // 2\n",
        "\n",
        "        if numbers[mid] == value:\n",
        "            return mid\n",
        "        elif numbers[mid] < value:\n",
        "            low = mid + 1\n",
        "        else:\n",
        "            high = mid - 1\n",
        "\n",
        "    return -1\n",
        "\n",
        "# Test avec l'exemple donné\n",
        "numbers = [1, 3, 5, 7, 9, 11]\n",
        "result = binary_search(numbers, 7)\n",
        "print(f\"Index de 7: {result}\")  # 3"
      ]
    },
