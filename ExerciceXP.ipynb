        "def insertion_sort(numbers: list) -> None:\n",
        "    \"\"\"\n",
        "    Trie une liste en place en utilisant l'algorithme du tri par insertion.\n",
        "\n",
        "    Args:\n",
        "        numbers: Liste d'éléments à trier (modifiée en place)\n",
        "\n",
        "    Returns:\n",
        "        None (la liste est modifiée en place)\n",
        "    \"\"\"\n",
        "    # Parcourir le tableau à partir du deuxième élément (indice 1)\n",
        "    for i in range(1, len(numbers)):\n",
        "        # Élément actuel à insérer dans la partie triée\n",
        "        current = numbers[i]\n",
        "        # Indice de l'élément précédent\n",
        "        j = i - 1\n",
        "\n",
        "        # Déplacer les éléments plus grands que current vers la droite\n",
        "        while j >= 0 and numbers[j] > current:\n",
        "            numbers[j + 1] = numbers[j]\n",
        "            j -= 1\n",
        "\n",
        "        # Insérer current à sa position correcte\n",
        "        numbers[j + 1] = current\n",
        "\n",
        "# Test avec l'exemple donné\n",
        "numbers = [5, 2, 9, 1, 5, 6]\n",
        "insertion_sort(numbers)\n",
        "print(f\"Tableau trié: {numbers}\")  # [1, 2, 5, 5, 6, 9]"
      ]
    },
