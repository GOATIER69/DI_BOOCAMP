    "import time\n",
    "import random\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "def linear_search(numbers: list, value: int) -> int:\n",
    "    \"\"\"Recherche linéaire pour comparaison.\"\"\"\n",
    "    for i, num in enumerate(numbers):\n",
    "        if num == value:\n",
    "            return i\n",
    "    return -1\n",
    "\n",
    "def compare_search_algorithms():\n",
    "    \"\"\"\n",
    "    Compare les performances de la recherche binaire vs linéaire.\n",
    "    \"\"\"\n",
    "    sizes = [10, 100, 1000, 10000, 100000]\n",
    "    times_binary = []\n",
    "    times_linear = []\n",
    "    \n",
    "    print(\"\\n=== COMPARAISON DES PERFORMANCES ===\")\n",
    "    print(f\"{'Taille':<10} {'Binaire (s)':<15} {'Linéaire (s)':<15} {'Ratio':<10}\")\n",
    "    print(\"-\" * 50)\n",
    "    \n",
    "    for size in sizes:\n",
    "        # Créer un tableau trié\n",
    "        numbers = list(range(size))\n",
    "        \n",
    "        # Chercher un élément qui existe (le dernier)\n",
    "        target = size - 1\n",
    "        \n",
    "        # Mesurer la recherche binaire\n",
    "        start = time.perf_counter()\n",
    "        binary_search(numbers, target)\n",
    "        binary_time = time.perf_counter() - start\n",
    "        \n",
    "        # Mesurer la recherche linéaire\n",
    "        start = time.perf_counter()\n",
    "        linear_search(numbers, target)\n",
    "        linear_time = time.perf_counter() - start\n",
    "        \n",
    "        times_binary.append(binary_time)\n",
    "        times_linear.append(linear_time)\n",
    "        \n",
    "        ratio = linear_time / binary_time if binary_time > 0 else 0\n",
    "        print(f\"{size:<10} {binary_time:<15.6f} {linear_time:<15.6f} {ratio:<10.2f}x\")\n",
    "    \n",
    "    # Visualisation\n",
    "    plt.figure(figsize=(12, 6))\n",
    "    \n",
    "    plt.subplot(1, 2, 1)\n",
    "    plt.plot(sizes, times_binary, 'b-o', label='Recherche Binaire O(log n)')\n",
    "    plt.plot(sizes, times_linear, 'r-s', label='Recherche Linéaire O(n)')\n",
    "    plt.xlabel('Taille du tableau')\n",
    "    plt.ylabel('Temps d\\'exécution (s)')\n",
    "    plt.title('Comparaison des performances')\n",
    "    plt.legend()\n",
    "    plt.grid(True, alpha=0.3)\n",
    "    \n",
    "    plt.subplot(1, 2, 2)\n",
    "    ratios = [l/b for l, b in zip(times_linear, times_binary)]\n",
    "    plt.plot(sizes, ratios, 'g-^', label='Ratio Linéaire/Binaire')\n",
    "    plt.xlabel('Taille du tableau')\n",
    "    plt.ylabel('Facteur d\\'accélération')\n",
    "    plt.title('Avantage de la recherche binaire')\n",
    "    plt.legend()\n",
    "    plt.grid(True, alpha=0.3)\n",
    "    \n",
    "    plt.tight_layout()\n",
    "    plt.show()\n",
    "\n",
    "compare_search_algorithms()"
   ]
