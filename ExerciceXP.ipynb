    "def insertion_sort_counted(numbers: list) -> tuple:\n",
    "    \"\"\"\n",
    "    Version du tri par insertion qui compte les opérations effectuées.\n",
    "    \n",
    "    Returns:\n",
    "        tuple: (liste triée, nombre de comparaisons, nombre de déplacements)\n",
    "    \"\"\"\n",
    "    comparisons = 0\n",
    "    shifts = 0\n",
    "    \n",
    "    for i in range(1, len(numbers)):\n",
    "        current = numbers[i]\n",
    "        j = i - 1\n",
    "        \n",
    "        while j >= 0 and numbers[j] > current:\n",
    "            comparisons += 1\n",
    "            numbers[j + 1] = numbers[j]\n",
    "            shifts += 1\n",
    "            j -= 1\n",
    "        \n",
    "        # Dernière comparaison qui échoue (si elle a lieu)\n",
    "        if j >= 0:\n",
    "            comparisons += 1\n",
    "        \n",
    "        numbers[j + 1] = current\n",
    "    \n",
    "    return numbers, comparisons, shifts\n",
    "\n",
    "# Test avec comptage\n",
    "numbers = [5, 2, 9, 1, 5, 6]\n",
    "sorted_numbers, comps, shifts = insertion_sort_counted(numbers.copy())\n",
    "print(f\"\\n=== STATISTIQUES ===\")\n",
    "print(f\"Tableau original: {[5, 2, 9, 1, 5, 6]}\")\n",
    "print(f\"Tableau trié: {sorted_numbers}\")\n",
    "print(f\"Nombre de comparaisons: {comps}\")\n",
    "print(f\"Nombre de déplacements: {shifts}\")"
   ]
